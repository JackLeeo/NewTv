# iOS pbxproj 必须用 LF（macOS Xcode / nanaimo 不接受 CRLF）
# 用文件路径精确匹配，避免误伤二进制文件
ios/Runner.xcodeproj/project.pbxproj text eol=lf
ios/Podfile text eol=lf
ios/Podfile.lock text eol=lf
ios/Runner/Info.plist text eol=lf
ios/Runner.xcodeproj/xcshareddata/** text eol=lf
ios/Flutter/Generated.xcconfig text eol=lf
ios/Flutter/Debug.xcconfig text eol=lf
ios/Flutter/Release.xcconfig text eol=lf
